from turtle import*

t = Turtle()

from time import sleep

t.speed(0)

def desenho_retangulo(x, y, largura, altura, color):
    t.penup()
    t.goto(x, y)
    t.pendown()

    t.begin_fill()
    t.fillcolor(color)
    for _ in range(2):
        t.fd(largura)
        t.lt(90)
        t.fd(altura)
        t.lt(90)
    t.end_fill()

def desenho_triangulo(x, y, cateto, hipotenusa, color):
    t.penup()
    t.goto(x, y)
    t.pendown()

    t.begin_fill()
    t.fillcolor(color)
    t.lt(90)
    for _ in range(2):
        t.rt(120)
        t.fd(cateto)
    t.rt(120)
    t.fd(hipotenusa)
    t.end_fill()
    t.rt(90)



def desenho_estrela(x, y, lados, color):
    t.penup()
    t.goto(x, y)
    t.pendown()

    t.begin_fill()
    t.fillcolor(color)
    for _ in range(5):
        t.fd(lados)
        t.rt(72)
        t.fd (lados)
        t.rt (144)
    t.end_fill()

#Bandeira da Ucrânia e Polônia (2 fáceis)

def desenho_bandeira_ucrania():
    desenho_retangulo(-300, -150, 600, 300, "yellow")
    desenho_retangulo(-300, 0, 600, 150, "#1E90FF")

desenho_bandeira_ucrania()
sleep(5)
t.clear()



def desenho_bandeira_polonia():
    desenho_retangulo(-300, -150, 600, 300, "red")
    desenho_retangulo(-300, 0, 600, 150, "white")

desenho_bandeira_polonia()
sleep(5)
t.clear()

