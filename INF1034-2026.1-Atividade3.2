#Bandeira da República Centro Africana e Honduras (2 difíceis)

def desenho_bandeira_republica_centro_africana():
    desenho_retangulo(-300, -150, 600, 75, "#F7C800")
    desenho_retangulo(-300, -75, 600, 75, "#279227")
    desenho_retangulo(-300, 0, 600, 75, "white")
    desenho_retangulo(-300, 75, 600, 75, "#002E7E")
    desenho_retangulo(-60, -150, 120, 300, "#CB0F32")
    desenho_estrela(-200, 120, 40, "#F7C800")

desenho_bandeira_republica_centro_africana()
sleep(5)
t.clear()



def desenho_bandeira_honduras():
    desenho_retangulo(-300, -150, 600, 300, "#0D3994")
    desenho_retangulo(-300, -50, 600, 100, "white")
    desenho_estrela(-120, -30, 20, "#0D3994")
    desenho_estrela(-120, 30, 20, "#0D3994")
    desenho_estrela(80, -30, 20, "#0D3994")
    desenho_estrela(80, 30, 20, "#0D3994")
    desenho_estrela(-20, 0, 20, "#0D3994")

desenho_bandeira_honduras()
sleep(5)
t.clear()

mainloop()
